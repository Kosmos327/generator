Thumbs.db
desktop.ini

# Gradle
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# Maven
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# Temporary files
*.tmp
*.bak
*.swp
*~
